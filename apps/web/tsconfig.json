{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
     "baseUrl": ".",
    "paths": {
      "@repo/*": ["packages/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
      
    ],
     
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
, "tailwind.config.js", "postcss.config.js"  ],
  "exclude": ["node_modules"]
}
